{
  "name": "hackbar-v2",
  "version": "2.6.0",
  "description": "HackBar for Firefox and Chromium (DevTools). WebExtension MV3, Vue 3.",
  "type": "module",
  "scripts": {
    "dev": "vite build --watch",
    "dev:chrome": "cross-env TARGET=chrome vite build --watch",
    "dev:firefox": "cross-env TARGET=firefox vite build --watch",
    "build": "vue-tsc --noEmit && vite build",
    "build:chrome": "cross-env TARGET=chrome pnpm run build",
    "build:firefox": "cross-env TARGET=firefox pnpm run build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "webextension",
    "hackbar",
    "devtools",
    "vue"
  ],
  "author": "Chewbaka",
  "license": "ISC",
  "dependencies": {
    "crypto-js": "^4.2.0",
    "vue": "^3.5.30",
    "webextension-polyfill": "^0.12.0"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.287",
    "@types/crypto-js": "^4.2.2",
    "@types/firefox-webext-browser": "^143.0.0",
    "@types/webextension-polyfill": "^0.12.5",
    "@vitejs/plugin-vue": "^6.0.5",
    "cross-env": "^10.1.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.1",
    "vite-plugin-web-extension": "^4.5.0",
    "vitest": "^3.2.4",
    "vue-tsc": "^3.2.6"
  },
  "packageManager": "pnpm@10.32.1+sha512.a706938f0e89ac1456b6563eab4edf1d1faf3368d1191fc5c59790e96dc918e4456ab2e67d613de1043d2e8c81f87303e6b40d4ffeca9df15ef1ad567348f2be"
}
